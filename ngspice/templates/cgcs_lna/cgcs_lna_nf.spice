Vin Vin GND dc 0 ac 1
V_DD VDD GND {v_dd}
XM5 net1 Vb4 net4 GND sky130_fd_pr__nfet_01v8 L={l_m} W={w_m5} nf=1 ad='int((nf+1)/2) * W/nf * 0.29' as='int((nf+2)/2) * W/nf * 0.29'
+ pd='2*int((nf+1)/2) * (W/nf + 0.29)' ps='2*int((nf+2)/2) * (W/nf + 0.29)' nrd='0.29 / W' nrs='0.29 / W' sa=0 sb=0 sd=0 mult=1 m=1
