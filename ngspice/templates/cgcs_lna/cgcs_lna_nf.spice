**** begin user architecture code


** design_variables_start
.param v_dd = 1.8
.param r_b  = 1e+4
.param c_1  = 1e-11
.param l_m  = 0.15

.param v_b1 = 0.9053
.param v_b2 = 0.9053
.param v_b3 = 0.9053
.param v_b4 = 0.9053
.param r_d1 = 105
.param r_d4 = 105
.param r_s5 = 105
.param c_d1 = 2.092e-12
.param c_d4 = 2.092e-12
.param c_s3 = 2.092e-12
.param c_s4 = 2.092e-12
.param w_m1 = 68.44
.param w_m2 = 24.11
.param w_m3 = 24.11
.param w_m4 = 24.11
.param w_m5 = 24.11
** design_variables_end

.control
set filetype=ascii

** let_knobs_start
let noise_pts = 500
let noise_fstart = 1e6
let noise_fstop = 8e9
let T_kelvin = 300.15
let Rin_ohm = 50
** let_knobs_end
op $ For convergence aids

set sqrnoise
noise v(Vout) Vin dec $&noise_pts $&noise_fstart $&noise_fstop 1
setplot noise1

let NoiseFactor = inoise_spectrum / (4 * $&boltz * $&T_kelvin * $&Rin_ohm)
let NoiseFigure = 10*log10(NoiseFactor)

write NoiseFigure.csv NoiseFigure
.endc


**** end user architecture code
**.ends
.GLOBAL GND
.GLOBAL VDD
.end
